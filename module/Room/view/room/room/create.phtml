<h1>Add Room</h1>

<p>
    This form uses a <strong>CSRF token</strong> (Lecture 20) because it writes data.<br>
    The hidden <code>csrf</code> field is generated by <code>Zend\Form\Element\Csrf</code>
    and checked automatically inside <code>isValid()</code>.
    Try forging a POST without it — ZF2 will reject the submission.
</p>

<?php
$form = $this->form;
$form->setAttribute('action', $this->url('room/create'));
$form->setAttribute('method', 'post');
$form->prepare();
?>

<div class="zf2-form" style="padding: 20px; background: #f8f8f8; border-radius: 4px; display: inline-block;">

    <?php echo $this->form()->openTag($form); ?>

        <div class="field"><?php echo $this->formRow($form->get('number')); ?></div>
        <div class="field"><?php echo $this->formRow($form->get('type')); ?></div>
        <div class="field"><?php echo $this->formRow($form->get('price')); ?></div>
        <div class="field"><?php echo $this->formRow($form->get('description')); ?></div>

        <?php // CSRF hidden field — must be rendered, otherwise token check fails ?>
        <?php echo $this->formHidden($form->get('csrf')); ?>

        <?php echo $this->formSubmit($form->get('submit')); ?>

    <?php echo $this->form()->closeTag(); ?>

</div>

<p><a href="<?php echo $this->url('room'); ?>">&larr; Back to Room List</a></p>

<style>
/* ZF2 formRow() appends errors as a plain <ul> after each field.
   This rule makes them visible as red italic text with no bullet points. */
.zf2-form ul {
    list-style: none;
    margin: 3px 0 0 0;
    padding: 0;
    color: #c0392b;
    font-size: 0.85em;
    font-style: italic;
}
</style>

<h1>Search Rooms</h1>

<p>
    This form is built with <strong>Zend\Form</strong> and validated by <strong>Zend\InputFilter</strong>.<br>
    Try submitting with letters in the price field — the InputFilter rejects it and
    <code>formRow()</code> displays the error automatically.
</p>

<?php
// Prepare the form: sets the action URL, finalises element attributes.
// Must be called before rendering.
$form = $this->form;
$form->setAttribute('action', $this->url('room/search'));
$form->setAttribute('method', 'post');
$form->prepare();
?>

<div class="zf2-form" style="padding: 15px; background: #f8f8f8; border-radius: 4px; margin-bottom: 20px; display: inline-block;">

    <?php echo $this->form()->openTag($form); ?>

        <div style="margin-bottom: 10px;">
            <?php
            // formRow() renders: <label> + <input/select> + any validation errors
            echo $this->formRow($form->get('type'));
            ?>
        </div>

        <div style="margin-bottom: 10px;">
            <?php echo $this->formRow($form->get('min_price')); ?>
        </div>

        <?php echo $this->formSubmit($form->get('submit')); ?>

    <?php echo $this->form()->closeTag(); ?>

</div>

<?php if ($this->searched): ?>

    <?php if (empty($this->rooms)): ?>
        <p style="color: #888;">No rooms match your search criteria.</p>
    <?php else: ?>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #2c7a2c; color: #fff;">
                    <th style="padding: 10px; text-align: left;">Room #</th>
                    <th style="padding: 10px; text-align: left;">Type</th>
                    <th style="padding: 10px; text-align: right;">Price/Night</th>
                    <th style="padding: 10px; text-align: left;">Description</th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($this->rooms as $room): ?>
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px;"><?php echo $this->escapeHtml($room->getNumber()); ?></td>
                    <td style="padding: 10px;"><?php echo $this->escapeHtml($room->getType()); ?></td>
                    <td style="padding: 10px; text-align: right;"><?php echo $room->getPrice(); ?> BGN</td>
                    <td style="padding: 10px;"><?php echo $this->escapeHtml($room->getDescription()); ?></td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    <?php endif; ?>

<?php endif; ?>

<p style="color: #666; font-size: 0.9em; margin-top: 20px;">
    <strong>What happens behind the scenes:</strong><br>
    1. <strong>GET</strong> — empty form is shown (no validation, no results).<br>
    2. <strong>POST</strong> — controller calls <code>$form->setData($request->getPost())</code>
       then <code>$form->isValid()</code>. If valid, <code>$form->getData()</code> returns
       the cleaned values. If invalid, the form object carries error messages that
       <code>formRow()</code> renders automatically next to each field.
</p>

<p><a href="<?php echo $this->url('room'); ?>">&larr; Back to Room List</a></p>

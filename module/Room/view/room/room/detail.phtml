    <h1>Room <?php echo $this->escapeHtml($this->room->getNumber()); ?> — <?php echo $this->escapeHtml($this->room->getType()); ?></h1>

    <table style="border-collapse: collapse; margin: 20px 0;">
        <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 8px; font-weight: bold;">Room Number:</td>
            <td style="padding: 8px;"><?php echo $this->escapeHtml($this->room->getNumber()); ?></td>
        </tr>
        <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 8px; font-weight: bold;">Type:</td>
            <td style="padding: 8px;"><?php echo $this->escapeHtml($this->room->getType()); ?></td>
        </tr>
        <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 8px; font-weight: bold;">Price per night:</td>
            <td style="padding: 8px;"><?php echo $this->room->getPrice(); ?> GBP</td>
        </tr>
        <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 8px; font-weight: bold;">Description:</td>
            <td style="padding: 8px;"><?php echo $this->escapeHtml($this->room->getDescription()); ?></td>
        </tr>
    </table>

    <?php
    $payment = $this->payment;
    $state   = $payment ? $payment['state'] : null;
    ?>

    <?php if ($state === 'COMPLETED'): ?>
        <div id="payment-status" style="background: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 15px; border-radius: 5px; margin: 20px 0;">
            <strong>Payment Successful</strong>
            <p style="margin: 5px 0 0;">Order <code><?php echo $this->escapeHtml($payment['order_id']); ?></code> — <?php echo $this->escapeHtml($payment['amount']); ?> <?php echo $this->escapeHtml($payment['currency']); ?> paid.</p>
        </div>

    <?php elseif ($state === 'FAILED'): ?>
        <div id="payment-status" style="background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 15px; border-radius: 5px; margin: 20px 0;">

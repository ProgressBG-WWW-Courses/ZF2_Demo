{
    "name": "zf2/hello-world",
    "description": "A simple Zend Framework 2 Hello World application",
    "type": "project",
    "license": "BSD-3-Clause",
    "require": {
        "php": ">=5.6",
        "zendframework/zendframework": "^2.5",
        "doctrine/doctrine-orm-module": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Application\\": "module/Application/src/Application/",
            "Room\\": "module/Room/src/Room/",
            "Auth\\": "module/Auth/src/Auth/",
            "Payment\\": "module/Payment/src/Payment/"
        }
    },
    "config": {
        "audit": {
            "abandoned": "ignore",
            "block-insecure": false
        }
    }
}

RewriteEngine On
# Do not rewrite requests to existing files or directories
RewriteCond %{REQUEST_FILENAME} -s [OR]
RewriteCond %{REQUEST_FILENAME} -l [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^.*$ - [L]
# Route everything else to index.php (the ZF2 front controller)
RewriteRule ^.*$ index.php [L]

# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=hotel_db
DB_USER=hotel_user
DB_PASSWORD=hotel_pass
DB_ROOT_PASSWORD=rootpass

# ── Revolut Merchant API ──────────────────────────────────────────────────────
REVOLUT_ENVIRONMENT=sandbox
REVOLUT_API_URL=https://sandbox-merchant.revolut.com
REVOLUT_API_SECRET_KEY=
REVOLUT_API_PUBLIC_KEY=
REVOLUT_WEBHOOK_SECRET=

# Public URL used for payment redirect/webhook callbacks (e.g. ngrok tunnel)
APP_PUBLIC_URL=
